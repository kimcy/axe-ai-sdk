{
  "name": "@axe-ai-sdk/react",
  "version": "0.0.11",
  "description": "React hooks for axe-ai-sdk — useChat with streaming, optimistic UI, persistence, abort/reload.",
  "license": "MIT",
  "author": "axe-ai-sdk contributors",
  "keywords": [
    "react",
    "hooks",
    "ai",
    "chat",
    "streaming",
    "sse",
    "useChat",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kimcy/axe-ai-sdk.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/kimcy/axe-ai-sdk/issues"
  },
  "homepage": "https://github.com/kimcy/axe-ai-sdk#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./styles/markdown.css",
    "./styles/markdown.css": "./styles/markdown.css"
  },
  "files": [
    "dist",
    "styles",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@axe-ai-sdk/core": "workspace:*",
    "highlight.js": "^11.11.1",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.9.0"
  }
}
