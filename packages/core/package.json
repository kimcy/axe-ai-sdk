{
  "name": "@axe-ai-sdk/core",
  "version": "0.0.1",
  "description": "Transport-agnostic streaming chat core — robust SSE parser, request-scoped state machine, first-class agent/tool/RAG metadata.",
  "license": "MIT",
  "author": "axe-ai-sdk contributors",
  "keywords": [
    "ai",
    "chat",
    "streaming",
    "sse",
    "server-sent-events",
    "llm",
    "openai",
    "anthropic",
    "mcp",
    "agent",
    "tool-use"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kimcy/axe-ai-sdk.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/kimcy/axe-ai-sdk/issues"
  },
  "homepage": "https://github.com/kimcy/axe-ai-sdk#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.9.0"
  }
}
